# BadBlood-Revival — Server environment variables
#
# Copy this file to .env and edit. Defaults below are tuned for LOCAL play
# (single PC, or you + friends on the same LAN). For internet hosting see
# the "PUBLIC HOSTING" section at the bottom.

# =============================================================================
# LOCAL PLAY — single PC or LAN
# =============================================================================
# These defaults work for: solo play, two players on the same PC, or a
# small group on the same Wi-Fi network. No domain needed.

DLBB_HOST=0.0.0.0
DLBB_HTTP_PORT=80
DLBB_PORT=443
DLBB_RELAY_PORT=47584

# Hostname kept as the original — patcher leaves it intact and the hosts
# file routes pls.dlbb.com -> 127.0.0.1.
DLBB_DOMAIN=pls.dlbb.com

# Database (relative to the server/ folder)
DLBB_DB_PATH=data/dlbb.db

# Logging
DLBB_LOG_LEVEL=INFO
DLBB_LOG_REQUESTS=1
DLBB_LOG_FILE=pls-emu.log

# Gameplay
DLBB_ENABLED_FEATURES=3071
DLBB_DEFAULT_SC=30000
DLBB_DEFAULT_HC=0

# =============================================================================
# PUBLIC HOSTING — VPS with your own domain
# =============================================================================
# If you're hosting publicly, uncomment and edit:

# DLBB_DOMAIN=pls.example.it    # your 12-char domain (e.g. dlbb.host.io)

# TLS termination is normally done by stunnel, so DLBB_USE_TLS stays off.
# DLBB_USE_TLS=0
# DLBB_TLS_CERT=certs/cert.pem
# DLBB_TLS_KEY=certs/key.pem

# Optional: serve a patched-client zip to launchers via /api/patch.
# Leave unset to disable the endpoint (recommended unless you maintain
# your own private patch mirror — Techland-derived binaries shouldn't be
# in this repo).
# DLBB_PATCH_DIR=/opt/badblood-revival/private/PATCH
