gamedll_x64_rwdi.dll.*
filesystem_x64_rwdi.dll
rd3d11_x64_rwdi.dll
ColdClientLoader.ini
# Whole patched-game folders (if accidentally created inside the repo)
Dying Light Bad Blood/
PATCH-PIE/
SERVER-VPS/
SERVER-VPS.rar
TESTER_PACKAGE.rar
backup_originals/
OLD-DEPOT-FINDINGS/

